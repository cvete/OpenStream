# OpenStream Production Environment Configuration
# Copy this file to .env.production and fill in your actual values

# =============================================================================
# CRITICAL: All values marked with ⚠️ MUST be changed before deploying
# =============================================================================

# Environment
NODE_ENV=production

# Server Configuration
PORT=3000

# Database Configuration
# ⚠️ REQUIRED: PostgreSQL credentials (used by docker-compose and API)
POSTGRES_USER=streaming
POSTGRES_PASSWORD=CHANGE_ME_USE_OPENSSL_RAND
POSTGRES_DB=streaming_db
# DATABASE_URL is built automatically in docker-compose from the above values.
# For bare-metal, set it directly:
# DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# Redis Configuration
# ⚠️ REQUIRED: Redis connection string
REDIS_URL=redis://hostname:6379

# JWT Authentication
# ⚠️ REQUIRED: Must be at least 32 characters, use a cryptographically random string
# Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Stream Token Security
# ⚠️ REQUIRED: Must be at least 32 characters, use a different value than JWT_SECRET
# Generate with: openssl rand -base64 32
TOKEN_SECRET=
TOKEN_EXPIRY_HOURS=4

# SRS Media Server
SRS_API_URL=http://srs:1985
SRS_RTMP_PORT=1935

# Webhook Security
# ⚠️ REQUIRED: Secret for webhook HMAC signatures (at least 32 characters)
# Generate with: openssl rand -base64 32
SRS_WEBHOOK_SECRET=

# ⚠️ REQUIRED: Comma-separated list of IPs allowed to send webhooks
# Include SRS server IP, localhost for testing
# Example: 127.0.0.1,::1,10.0.0.5,172.18.0.0/16
SRS_WEBHOOK_IP_WHITELIST=127.0.0.1,::1

# CORS Configuration
# ⚠️ REQUIRED: Comma-separated list of allowed origins (no trailing slashes)
# Example: https://stream.example.com,https://admin.example.com
ALLOWED_ORIGINS=https://yourdomain.com

# Media Storage
MEDIA_PATH=/media
MEDIA_LIVE_PATH=/media/live
MEDIA_VOD_PATH=/media/vod

# Stream Configuration
MAX_VIEWERS_PER_STREAM=5000

# Error Tracking (Optional but recommended)
# Get a free account at https://sentry.io
SENTRY_DSN=

# Monitoring (Optional)
# Add your monitoring service DSN/API keys here
# DATADOG_API_KEY=
# NEW_RELIC_LICENSE_KEY=

# =============================================================================
# Security Checklist
# =============================================================================
# ✅ All secrets are at least 32 characters
# ✅ JWT_SECRET and TOKEN_SECRET are different values
# ✅ No default values remain (no "change-in-production" strings)
# ✅ ALLOWED_ORIGINS includes only your actual domains
# ✅ SRS_WEBHOOK_IP_WHITELIST includes only trusted IPs
# ✅ Database uses strong password
# ✅ Redis is password-protected if exposed to network

# =============================================================================
# Deployment Notes
# =============================================================================
# 1. Run database migrations: npm run migrate
# 2. Test configuration: npm run test:config
# 3. Start server: npm start
# 4. Verify health: curl http://localhost:3000/health
# 5. Monitor logs for any configuration warnings
